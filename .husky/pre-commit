#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run lint-staged for fast lint+format on staged files only
npx lint-staged

# Run gitleaks against staged changes if available
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner --redact || {
    echo "gitleaks detected secrets in staged changes. Aborting commit."
    exit 1
  }
else
  echo "gitleaks not installed; skipping secret scan. Install via: brew install gitleaks"
fi
