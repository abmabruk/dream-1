# ─────────────────────────────────────────────────────────────────
# Dream-1 environment template
# Copy to .env (local) or set in Vercel project settings (production)
# ─────────────────────────────────────────────────────────────────

# REQUIRED — Database (Postgres / Neon)
# For Neon: pick a region close to KSA (eu-central-1 / me-central-1)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dream_1?schema=public"

# REQUIRED — Session signing + TOTP encryption (32+ random chars)
# Generate: openssl rand -base64 64
AUTH_SECRET="replace-with-a-long-random-secret-32-chars-min"

# REQUIRED — Public app URL (no trailing slash)
APP_URL="http://localhost:2500"

# Optional — initial seeded OWNER password (defaults to "dream12345" in dev only)
# Production seed REQUIRES setting this AND ALLOW_PROD_SEED=true
# INITIAL_ADMIN_PASSWORD=

# Optional — allow seeding a production database (defaults: refuses)
# ALLOW_PROD_SEED=true

# Optional — Vercel Cron auth (set in production)
# Generate: openssl rand -base64 32
# CRON_SECRET=
# Dev convenience: ALLOW_UNAUTH_CRON=true (NEVER set in production)

# Optional — feature flags (defaults: all off)
# FLAGS_QUOTES=true
# FLAGS_INVOICES=true
# FLAGS_PAYMENTS=true
# FLAGS_VENDORS=true
# FLAGS_PRODUCTS=true
# FLAGS_TWO_FACTOR_AUTH=true

# Optional — observability
# LOG_LEVEL=info               # trace|debug|info|warn|error|fatal
# SENTRY_DSN=                  # server-side errors
# NEXT_PUBLIC_SENTRY_DSN=      # client-side errors (separate DSN)
# SENTRY_ENV=production
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=           # build-time source map upload
