generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  FACTORY_MANAGER
  SALES_MANAGER
  SUPERVISOR
  WORKER
  ACCOUNTANT
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum InquiryStage {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum InquirySource {
  INSTAGRAM
  TIKTOK
  SNAPCHAT
  WHATSAPP
  GOOGLE
  REFERRAL
  WALK_IN
  OTHER
}

enum OrderStatus {
  DRAFT
  QUOTED
  APPROVED
  IN_PRODUCTION
  QUALITY_CHECK
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderEventType {
  CREATED
  STATUS_CHANGED
  ASSIGNMENT_CREATED
  ASSIGNMENT_STATUS_CHANGED
  PORTAL_SHARED
  PORTAL_APPROVED
}

enum AssignmentStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum NotificationStatus {
  UNREAD
  READ
}

enum NotificationChannel {
  IN_APP
}

enum NotificationType {
  ORDER_OVERDUE
  CRM_FOLLOW_UP_DUE
  ASSIGNMENT_BLOCKED
  CUSTOMER_APPROVAL_PENDING
  TASK_MENTIONED
  TASK_COMMENT
  STAGE_STARTED
  DEPOSIT_ATTESTED
  QUOTE_APPROVED
  QUOTE_REJECTED
  QUOTE_EXPIRING_SOON
  INVOICE_SENT
  INVOICE_OVERDUE
  INVOICE_PAID
  PAYMENT_RECEIVED
}

enum ProjectStatus {
  PLANNING
  READY
  IN_PROGRESS
  ON_HOLD
  BLOCKED
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectTaskStatus {
  BACKLOG
  PLANNED_TODAY
  IN_PROGRESS
  WAITING_APPROVAL
  BLOCKED
  DONE
  CANCELLED
}

enum TaskApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum WorkQueueStatus {
  PLANNED
  IN_PROGRESS
  WAITING_APPROVAL
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  TASK_CREATED
  TASK_UPDATED
  TASK_ADDED_TO_TODAY
  QUEUE_REORDERED
  QUEUE_STATUS_CHANGED
  TASK_APPROVED
  TASK_REJECTED
  COST_ADDED
  COST_DELETED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  TASK_MENTION
  STAGE_STARTED
  STAGE_COMPLETED
  STAGE_SKIPPED
  STAGE_BLOCKED
  DEPOSIT_ATTESTED
  LOCATION_ADDED
}

enum CostCategory {
  MATERIAL
  LABOR
  SERVICE
  OVERHEAD
  OTHER
}

enum StageInstanceStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  SKIPPED
}

model Factory {
  id                String                 @id @default(cuid())
  name              String
  slug              String                 @unique
  timezone          String                 @default("Asia/Riyadh")
  currency          String                 @default("SAR")
  orderCodePrefix   String                 @default("DRM")
  portalDisplayName String?
  supportEmail      String?
  supportPhone      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  users             User[]
  inquiries         Inquiry[]
  customers         Customer[]
  orders            Order[]
  orderEvents       OrderEvent[]
  portalAccesses    OrderPortalAccess[]
  assignments       Assignment[]
  attendance        AttendanceRecord[]
  notifications     Notification[]
  projects          Project[]
  projectTasks      ProjectTask[]
  workQueueItems    WorkQueueItem[]
  projectActivities ProjectActivity[]
  projectCosts      ProjectCost[]
  taskAttachments   TaskAttachment[]
  taskComments      TaskComment[]
  stages            ProjectStage[]
  stageInstances    ProjectStageInstance[]
  locations         Location[]
  auditLogs         AuditLog[]
  quotes            Quote[]
  quoteLines        QuoteLine[]
  vendors           Vendor[]
  products          Product[]
  invoices          Invoice[]
  creditNotes       CreditNote[]
  payments          Payment[]
  taxNumber         String?
  address           String?
}

model User {
  id                      String                 @id @default(cuid())
  factoryId               String
  email                   String                 @unique
  passwordHash            String?
  firstName               String
  lastName                String
  phone                   String?
  role                    UserRole
  status                  UserStatus             @default(INVITED)
  totpSecret              String?
  totpEnabled             Boolean                @default(false)
  totpRecoveryCodes       String[]               @default([])
  totpEnabledAt           DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  factory                 Factory                @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  sessions                Session[]
  assignedInquiries       Inquiry[]              @relation("InquiryAssignee")
  assignments             Assignment[]
  ownedOrders             Order[]                @relation("OrderOwner")
  createdOrders           Order[]                @relation("OrderCreatedBy")
  orderEvents             OrderEvent[]           @relation("OrderEventActor")
  sharedPortalAccesses    OrderPortalAccess[]    @relation("PortalAccessSharedBy")
  attendance              AttendanceRecord[]
  notifications           Notification[]
  ownedProjects           Project[]              @relation("ProjectOwner")
  assignedProjectTasks    ProjectTask[]          @relation("ProjectTaskAssignee")
  approvedProjectTasks    ProjectTask[]          @relation("ProjectTaskApprover")
  workQueueAssignments    WorkQueueItem[]        @relation("WorkQueueAssignee")
  projectActivities       ProjectActivity[]      @relation("ProjectActivityActor")
  createdProjectCosts     ProjectCost[]          @relation("ProjectCostCreatedBy")
  uploadedTaskAttachments TaskAttachment[]       @relation("TaskAttachmentUploadedBy")
  authoredTaskComments    TaskComment[]          @relation("TaskCommentAuthor")
  stageInstancesOwned     ProjectStageInstance[] @relation("StageInstanceOwner")
  auditLogsActed          AuditLog[]             @relation("AuditLogActor")
  quotesCreated           Quote[]                @relation("QuoteCreatedBy")
  quotesApproved          Quote[]                @relation("QuoteApprovedBy")
  inquiriesConverted      Inquiry[]              @relation("InquiryConvertedBy")
  vendorsCreated          Vendor[]               @relation("VendorCreatedBy")
  productsCreated         Product[]              @relation("ProductCreatedBy")
  invoicesCreated         Invoice[]              @relation("InvoiceCreatedBy")
  creditNotesCreated      CreditNote[]           @relation("CreditNoteCreatedBy")
  paymentsRecorded        Payment[]              @relation("PaymentRecordedBy")
  customerProfile         Customer?              @relation("CustomerUser")

  @@index([factoryId, role])
}

model Inquiry {
  id                  String        @id @default(cuid())
  factoryId           String
  assignedToId        String?
  name                String
  phone               String
  email               String?
  source              InquirySource @default(OTHER)
  stage               InquiryStage  @default(NEW)
  interest            String?
  budgetAmount        Decimal?      @db.Decimal(14, 2)
  nextFollowUpAt      DateTime?
  notes               String?
  convertedCustomerId String?
  convertedOrderId    String?
  convertedAt         DateTime?
  convertedByUserId   String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  factory             Factory       @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  assignedTo          User?         @relation("InquiryAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  convertedCustomer   Customer?     @relation("InquiryConvertedCustomer", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  convertedOrder      Order?        @relation("InquiryConvertedOrder", fields: [convertedOrderId], references: [id], onDelete: SetNull)
  convertedBy         User?         @relation("InquiryConvertedBy", fields: [convertedByUserId], references: [id], onDelete: SetNull)

  @@index([factoryId, stage, nextFollowUpAt])
  @@index([convertedCustomerId])
  @@index([convertedOrderId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Customer {
  id                     String    @id @default(cuid())
  factoryId              String
  name                   String
  email                  String?
  phone                  String?
  city                   String?
  district               String?
  taxNumber              String?
  address                String?
  notes                  String?
  userId                 String?   @unique
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  factory                Factory   @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  user                   User?     @relation("CustomerUser", fields: [userId], references: [id], onDelete: SetNull)
  orders                 Order[]
  invoices               Invoice[]
  payments               Payment[]
  convertedFromInquiries Inquiry[] @relation("InquiryConvertedCustomer")

  @@index([factoryId, name])
}

model Order {
  id                     String             @id @default(cuid())
  factoryId              String
  customerId             String
  ownerId                String?
  createdById            String?
  code                   String
  title                  String
  description            String?
  status                 OrderStatus        @default(DRAFT)
  quotedAmount           Decimal?           @db.Decimal(14, 2)
  targetDate             DateTime?
  approvedAt             DateTime?
  customerApprovedAt     DateTime?
  customerApprovalNote   String?
  deliveredAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  factory                Factory            @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  customer               Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  owner                  User?              @relation("OrderOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy              User?              @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  portalAccess           OrderPortalAccess?
  events                 OrderEvent[]
  assignments            Assignment[]
  projects               Project[]
  quotes                 Quote[]
  invoices               Invoice[]
  convertedFromInquiries Inquiry[]          @relation("InquiryConvertedOrder")

  @@unique([factoryId, code])
  @@index([factoryId, status])
  @@index([customerId])
}

model OrderPortalAccess {
  id           String    @id @default(cuid())
  factoryId    String
  orderId      String    @unique
  sharedById   String?
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  factory      Factory   @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sharedBy     User?     @relation("PortalAccessSharedBy", fields: [sharedById], references: [id], onDelete: SetNull)

  @@index([factoryId, createdAt])
}

model OrderEvent {
  id         String         @id @default(cuid())
  factoryId  String
  orderId    String
  actorId    String?
  type       OrderEventType
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  note       String?
  createdAt  DateTime       @default(now())
  factory    Factory        @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor      User?          @relation("OrderEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([factoryId, orderId, createdAt])
}

model Assignment {
  id           String           @id @default(cuid())
  factoryId    String
  orderId      String
  workerId     String
  station      String
  status       AssignmentStatus @default(PLANNED)
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  factory      Factory          @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  worker       User             @relation(fields: [workerId], references: [id], onDelete: Restrict)

  @@index([factoryId, status, scheduledFor])
  @@index([orderId])
  @@index([workerId])
}

model AttendanceRecord {
  id         String    @id @default(cuid())
  factoryId  String
  userId     String
  date       DateTime
  clockInAt  DateTime?
  clockOutAt DateTime?
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  factory    Factory   @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([factoryId, userId, date])
  @@index([factoryId, date])
}

model Notification {
  id         String              @id @default(cuid())
  factoryId  String
  userId     String
  type       NotificationType
  channel    NotificationChannel @default(IN_APP)
  status     NotificationStatus  @default(UNREAD)
  dedupeKey  String
  title      String
  message    String
  href       String?
  entityType String?
  entityId   String?
  readAt     DateTime?
  resolvedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  factory    Factory             @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([factoryId, userId, status, resolvedAt, createdAt])
  @@index([factoryId, userId, type, resolvedAt])
}

model Project {
  id             String                 @id @default(cuid())
  factoryId      String
  orderId        String?
  ownerUserId    String?
  code           String
  name           String
  description    String?
  status         ProjectStatus          @default(PLANNING)
  priority       ProjectPriority        @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  notes          String?
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  factory        Factory                @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  order          Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  owner          User?                  @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks          ProjectTask[]
  activities     ProjectActivity[]
  costs          ProjectCost[]
  stageInstances ProjectStageInstance[]
  locations      Location[]

  @@unique([factoryId, code])
  @@index([factoryId, status, priority, dueDate])
  @@index([factoryId, sortOrder])
  @@index([orderId])
  @@index([ownerUserId])
}

model ProjectTask {
  id               String                @id @default(cuid())
  factoryId        String
  projectId        String
  assignedToUserId String?
  approvedByUserId String?
  title            String
  description      String?
  status           ProjectTaskStatus     @default(BACKLOG)
  priority         ProjectPriority       @default(MEDIUM)
  requiresApproval Boolean               @default(false)
  approvalStatus   TaskApprovalStatus    @default(NOT_REQUIRED)
  dueDate          DateTime?
  completedAt      DateTime?
  approvedAt       DateTime?
  rejectedReason   String?
  sortOrder        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  stageInstanceId  String?
  locationId       String?
  factory          Factory               @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  project          Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo       User?                 @relation("ProjectTaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  approvedBy       User?                 @relation("ProjectTaskApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  stageInstance    ProjectStageInstance? @relation(fields: [stageInstanceId], references: [id], onDelete: SetNull)
  location         Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  queueItems       WorkQueueItem[]
  activities       ProjectActivity[]
  costs            ProjectCost[]
  attachments      TaskAttachment[]
  comments         TaskComment[]

  @@index([factoryId, projectId, status, priority])
  @@index([assignedToUserId])
  @@index([approvedByUserId])
}

model WorkQueueItem {
  id               String          @id @default(cuid())
  factoryId        String
  taskId           String
  assignedToUserId String?
  workDate         DateTime
  position         Int
  status           WorkQueueStatus @default(PLANNED)
  startedAt        DateTime?
  completedAt      DateTime?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  factory          Factory         @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  task             ProjectTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedTo       User?           @relation("WorkQueueAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@unique([taskId, workDate])
  @@unique([factoryId, workDate, position])
  @@index([factoryId, workDate, status, position])
  @@index([assignedToUserId])
}

model ProjectActivity {
  id              String                @id @default(cuid())
  factoryId       String
  projectId       String
  taskId          String?
  actorUserId     String?
  type            ProjectActivityType
  message         String
  createdAt       DateTime              @default(now())
  stageInstanceId String?
  factory         Factory               @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            ProjectTask?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor           User?                 @relation("ProjectActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  stageInstance   ProjectStageInstance? @relation(fields: [stageInstanceId], references: [id], onDelete: SetNull)

  @@index([factoryId, projectId, createdAt])
  @@index([taskId])
  @@index([actorUserId])
  @@index([stageInstanceId])
}

model ProjectCost {
  id              String                @id @default(cuid())
  factoryId       String
  projectId       String
  taskId          String?
  category        CostCategory          @default(OTHER)
  amount          Decimal               @db.Decimal(14, 2)
  currency        String                @default("SAR")
  description     String
  vendorName      String?
  receiptUrl      String?
  incurredAt      DateTime
  createdById     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  stageInstanceId String?
  locationId      String?
  quoteLineId     String?
  vendorId        String?
  factory         Factory               @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            ProjectTask?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdBy       User?                 @relation("ProjectCostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  stageInstance   ProjectStageInstance? @relation(fields: [stageInstanceId], references: [id], onDelete: SetNull)
  location        Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  quoteLine       QuoteLine?            @relation(fields: [quoteLineId], references: [id], onDelete: SetNull)
  vendor          Vendor?               @relation("VendorCosts", fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([factoryId, projectId, incurredAt])
  @@index([factoryId, category])
  @@index([taskId])
  @@index([locationId])
  @@index([quoteLineId])
  @@index([vendorId])
}

model TaskAttachment {
  id           String      @id @default(cuid())
  factoryId    String
  taskId       String
  filename     String
  storedName   String
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  createdAt    DateTime    @default(now())
  factory      Factory     @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  task         ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User?       @relation("TaskAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([factoryId, taskId, createdAt])
}

model TaskComment {
  id        String      @id @default(cuid())
  factoryId String
  taskId    String
  authorId  String?
  body      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  factory   Factory     @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  task      ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User?       @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([factoryId, taskId, createdAt])
}

model ProjectStage {
  id                         String                 @id @default(cuid())
  factoryId                  String
  slug                       String
  name                       String
  description                String?
  ownerRole                  UserRole?
  sortOrder                  Int
  isOptional                 Boolean                @default(false)
  requiresDepositAttestation Boolean                @default(false)
  expectedDays               Int?
  isActive                   Boolean                @default(true)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  factory                    Factory                @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  instances                  ProjectStageInstance[]

  @@unique([factoryId, slug])
  @@index([factoryId, sortOrder])
}

model ProjectStageInstance {
  id                String              @id @default(cuid())
  factoryId         String
  projectId         String
  stageId           String
  status            StageInstanceStatus @default(NOT_STARTED)
  startedAt         DateTime?
  completedAt       DateTime?
  ownerUserId       String?
  notes             String?
  depositAttested   Boolean             @default(false)
  depositAmount     Decimal?            @db.Decimal(14, 2)
  depositReceivedAt DateTime?
  depositMethod     String?
  depositReceiptUrl String?
  depositNote       String?
  drawingsApproved  Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  factory           Factory             @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage             ProjectStage        @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner             User?               @relation("StageInstanceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks             ProjectTask[]
  costs             ProjectCost[]
  activities        ProjectActivity[]

  @@unique([projectId, stageId])
  @@index([factoryId, projectId])
  @@index([status])
}

model Location {
  id           String        @id @default(cuid())
  factoryId    String
  projectId    String
  name         String
  code         String?
  notes        String?
  sortOrder    Int           @default(0)
  isTemplate   Boolean       @default(false)
  quotedAmount Decimal?      @db.Decimal(14, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  factory      Factory       @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        ProjectTask[]
  costs        ProjectCost[]

  @@index([factoryId, projectId, sortOrder])
}

enum AuditOutcome {
  SUCCESS
  FAILURE
}

model AuditLog {
  id                String       @id @default(cuid())
  factoryId         String?
  actorUserId       String?
  actorRoleSnapshot String?
  action            String
  entityType        String?
  entityId          String?
  outcome           AuditOutcome @default(SUCCESS)
  ipAddress         String?
  userAgent         String?
  requestId         String?
  metadata          Json?
  createdAt         DateTime     @default(now())

  factory Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  actor   User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([factoryId, createdAt])
  @@index([factoryId, action, createdAt])
  @@index([factoryId, entityType, entityId])
  @@index([actorUserId, createdAt])
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  SUPERSEDED
  REJECTED
  CANCELLED
  EXPIRED
}

model Quote {
  id            String      @id @default(cuid())
  factoryId     String
  orderId       String
  version       Int         @default(1)
  status        QuoteStatus @default(DRAFT)
  parentQuoteId String?

  currency       String  @default("SAR")
  taxRate        Decimal @default(15.00) @db.Decimal(5, 2)
  taxInclusive   Boolean @default(false)
  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @db.Decimal(14, 2)
  discountReason String?
  taxAmount      Decimal @default(0) @db.Decimal(14, 2)
  total          Decimal @default(0) @db.Decimal(14, 2)

  validUntil       DateTime?
  sentToCustomerAt DateTime?
  approvedAt       DateTime?
  approvedById     String?

  notes         String?
  internalNotes String?

  deletedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  factory    Factory     @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parent     Quote?      @relation("QuoteParent", fields: [parentQuoteId], references: [id], onDelete: SetNull)
  children   Quote[]     @relation("QuoteParent")
  createdBy  User?       @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy User?       @relation("QuoteApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lines      QuoteLine[]
  invoices   Invoice[]

  @@unique([orderId, version])
  @@index([factoryId, status, orderId])
  @@index([factoryId, validUntil])
  @@index([deletedAt])
}

model QuoteLine {
  id        String @id @default(cuid())
  factoryId String
  quoteId   String
  sortOrder Int    @default(0)

  productId String?

  description String
  sku         String?
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factory Factory  @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation("QuoteLineProduct", fields: [productId], references: [id], onDelete: SetNull)

  costs ProjectCost[]

  @@index([quoteId, sortOrder])
  @@index([factoryId, productId])
}

// ────────────────────────────────────────────────────────────
// Vendors (suppliers)
// ────────────────────────────────────────────────────────────
model Vendor {
  id                String  @id @default(cuid())
  factoryId         String
  name              String
  normalizedName    String // LOWER(TRIM(REGEXP_REPLACE(name, '\s+', ' ', 'g'))) — for dedup
  code              String? // optional internal code
  taxNumber         String? // VAT number
  email             String?
  phone             String?
  website           String?
  address           String?
  city              String?
  paymentTermsDays  Int? // typical net days (30, 60, etc.)
  preferredCurrency String? // default null = factory currency
  notes             String?

  // Soft delete + audit
  deletedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  factory   Factory         @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("VendorCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  contacts  VendorContact[]
  costs     ProjectCost[]   @relation("VendorCosts")

  @@unique([factoryId, normalizedName])
  @@index([factoryId, deletedAt])
  @@index([factoryId, code])
}

model VendorContact {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  role      String? // e.g. "مدير المبيعات"
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

// ────────────────────────────────────────────────────────────
// Products (catalog)
// ────────────────────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  factoryId   String
  code        String // SKU — unique per factory
  name        String
  description String?
  category    String? // free-text for now (proper category tree later if needed)
  tags        String[] @default([])

  // Pricing
  defaultUnitPrice  Decimal @default(0) @db.Decimal(14, 4) // sell price
  estimatedUnitCost Decimal @default(0) @db.Decimal(14, 4) // baseline cost for margin estimates
  currency          String  @default("SAR")

  // Stock (basic — full inventory later)
  lowStockThreshold Int? // alert threshold; null = don't track

  // Soft delete + audit
  deletedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  factory    Factory          @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  createdBy  User?            @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  variants   ProductVariant[]
  quoteLines QuoteLine[]      @relation("QuoteLineProduct")

  @@unique([factoryId, code])
  @@index([factoryId, deletedAt])
  @@index([factoryId, category])
}

model ProductVariant {
  id                     String   @id @default(cuid())
  productId              String
  code                   String // variant SKU suffix
  name                   String // e.g. "أحمر / كبير"
  attributes             Json     @default("{}") // {color: "red", size: "L"}
  unitPriceDelta         Decimal  @default(0) @db.Decimal(14, 4) // adds to product.defaultUnitPrice
  estimatedUnitCostDelta Decimal  @default(0) @db.Decimal(14, 4)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, code])
  @@index([productId, isActive])
}

// ────────────────────────────────────────────────────────────
// Invoices
// ────────────────────────────────────────────────────────────
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id        String  @id @default(cuid())
  factoryId String
  customerId String
  orderId   String? // optional — invoice can stand alone or be tied to an order
  quoteId   String? // source quote (immutable reference)
  number    String // human-readable, sequential per factory (e.g. "INV-2026-00042")
  numberSeq Int // raw sequence; for advisory-lock generation

  status InvoiceStatus @default(DRAFT)

  issueDate    DateTime  @default(now())
  dueDate      DateTime?
  sentAt       DateTime?
  voidedAt     DateTime?
  voidedReason String?

  // Pricing — snapshot from Quote at generation time
  currency       String  @default("SAR")
  taxRate        Decimal @default(15.00) @db.Decimal(5, 2)
  taxInclusive   Boolean @default(false)
  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @db.Decimal(14, 2)
  taxAmount      Decimal @default(0) @db.Decimal(14, 2)
  total          Decimal @default(0) @db.Decimal(14, 2)
  amountPaid     Decimal @default(0) @db.Decimal(14, 2) // running total of allocated payments

  // Snapshot of seller (Factory) and buyer (Customer) at invoice issue time
  // Useful when factory/customer data changes later
  sellerNameSnapshot      String?
  sellerTaxNumberSnapshot String?
  sellerAddressSnapshot   String?
  buyerNameSnapshot       String?
  buyerTaxNumberSnapshot  String?
  buyerAddressSnapshot    String?

  notes         String?
  internalNotes String?

  // Soft delete + audit
  deletedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  factory     Factory       @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order       Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  quote       Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  createdBy   User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines              InvoiceLine[]
  creditNotes        CreditNote[]
  paymentAllocations PaymentAllocation[]

  @@unique([factoryId, number])
  @@index([factoryId, status, dueDate])
  @@index([factoryId, customerId, issueDate])
  @@index([factoryId, deletedAt])
}

model InvoiceLine {
  id        String @id @default(cuid())
  invoiceId String
  sortOrder Int    @default(0)

  // Snapshot fields (immutable copy at time of generation)
  description String
  sku         String?
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  // Optional traceability back to source line
  productId   String? // not enforced as FK (snapshot, product may be deleted)
  quoteLineId String? // not enforced as FK

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sortOrder])
}

// ────────────────────────────────────────────────────────────
// Credit Notes (for refunds, returns, partial reversals)
// ────────────────────────────────────────────────────────────
enum CreditNoteStatus {
  DRAFT
  ISSUED
  VOID
}

model CreditNote {
  id        String @id @default(cuid())
  factoryId String
  invoiceId String
  number    String // sequential per factory: "CN-2026-00001"
  numberSeq Int

  status CreditNoteStatus @default(DRAFT)

  reason String // why issued (return, cancellation, billing error)

  currency  String  @default("SAR")
  taxRate   Decimal @default(15.00) @db.Decimal(5, 2)
  subtotal  Decimal @default(0) @db.Decimal(14, 2)
  taxAmount Decimal @default(0) @db.Decimal(14, 2)
  total     Decimal @default(0) @db.Decimal(14, 2)

  issuedAt DateTime?
  voidedAt DateTime?

  // Soft delete + audit
  deletedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  factory   Factory          @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  invoice   Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User?            @relation("CreditNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines     CreditNoteLine[]

  @@unique([factoryId, number])
  @@index([factoryId, invoiceId])
  @@index([factoryId, status, issuedAt])
}

model CreditNoteLine {
  id           String @id @default(cuid())
  creditNoteId String
  sortOrder    Int    @default(0)

  description String
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  // Optional reference back to invoice line being credited
  invoiceLineId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId, sortOrder])
}

// ────────────────────────────────────────────────────────────
// Payments (manual entry only — no online gateway)
// ────────────────────────────────────────────────────────────
enum PaymentKind {
  PAYMENT
  REFUND
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
  OTHER
}

model Payment {
  id           String        @id @default(cuid())
  factoryId    String
  customerId   String
  kind         PaymentKind   @default(PAYMENT)
  method       PaymentMethod @default(BANK_TRANSFER)
  reference    String?       // bank reference, check number, etc.
  receivedAt   DateTime      @default(now())
  amount       Decimal       @db.Decimal(14, 2)
  currency     String        @default("SAR")
  notes        String?

  // Soft delete + audit
  deletedAt    DateTime?
  recordedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  factory     Factory             @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  recordedBy  User?               @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  allocations PaymentAllocation[]

  @@index([factoryId, customerId, receivedAt])
  @@index([factoryId, kind, receivedAt])
  @@index([factoryId, deletedAt])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
  @@index([paymentId])
}
